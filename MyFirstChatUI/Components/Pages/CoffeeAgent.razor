@page "/coffee-agent"
@using GroqApiLibrary
@using Microsoft.Extensions.AI
@using MyFirstChatUI.Agents
@using MyFirstChatUI.Helpers.Groq
@using MyFirstChatUI.Models
@using System.Text.Json.Nodes

@inject CoffeeData CoffeeDataService
@inject IConfiguration configuration

<PageTitle>Coffee Data</PageTitle>

<ChatMessageWrapper>
    @{
        var messages = chatHistory.Cast<JsonObject>().Select(msg => new
        {
            Role = Convert.ToString(msg["role"]),
            Content = Convert.ToString(msg["content"])
        }).ToList();

        foreach (var message in messages)
        {
            if (message.Role == ChatRole.Assistant.ToString())
            {
                <AssistantMessage>
                    <MarkdownText Text="@message.Content"></MarkdownText>
                </AssistantMessage>
            }
            else if (message.Role == ChatRole.User.ToString())
            {
                <UserMessage>
                    <MarkdownText Text="@message.Content"></MarkdownText>
                </UserMessage>
            }
        }
    }
    <LoadingIndicator IsLoading="isLoading" StreamingText="@streamingText" />
</ChatMessageWrapper>

<ChatInput OnSendMessage="HandleSendMessage" IsLoading="isLoading" />
@code {
#pragma warning disable OPENAI001

    private CoffeeFileAgent agent = null!;
    private JsonArray chatHistory = [];
    private JsonArray customHistory = [];
    private bool isLoading;
    string streamingText = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        streamingText = "Loading Coffee Agent...";

        agent = await CoffeeFileAgent.CreateAsync(CoffeeDataService, configuration);
        if (agent is null) throw new InvalidOperationException("Unable to create Agent");

        chatHistory = new JsonArray
        {
            new JsonObject
            {
                ["role"] = ChatRole.System.ToString(),
                ["content"] = agent.systemPrompt
            },
            new JsonObject
            {
                ["role"] = ChatRole.Assistant.ToString(),
                ["content"] = "Ask me anything about our coffee selection."
            },
        };

        streamingText = string.Empty;
        isLoading = false;
    }

    public async Task HandleSendMessage(string prompt)
    {
        isLoading = true;
        try
        {
            chatHistory.Add(new JsonObject
            {
                ["role"] = Convert.ToString(ChatRole.User),
                ["content"] = prompt
            });

            var response = await agent.GetCustomResponseAsync(RequestHelper.DeepCloneMessages(chatHistory));

            chatHistory.Add(new JsonObject
            {
                ["role"] = response.Role,
                ["content"] = response.Content,
            });
        }
        catch (Exception e)
        {

        }
        isLoading = false;
    }

#pragma warning restore OPENAI001
}