@page "/"
@page "/chat"
@using GroqApiLibrary
@using System.Text.Json.Nodes
@using Microsoft.Extensions.AI
@using MyFirstChatUI.Helpers.Groq
@inject IConfiguration configuration

<PageTitle>Home</PageTitle>
<ChatMessageWrapper>
    @{
        var messages = history.Cast<JsonObject>().Select(msg => new
        {
            Role = Convert.ToString(msg["role"]),
            Content = Convert.ToString(msg["content"])
        }).ToList();

        foreach (var message in messages)
        {
            if (message.Role == ChatRole.Assistant.ToString())
            {
                <AssistantMessage>
                    <MarkdownText Text="@message.Content"></MarkdownText>
                </AssistantMessage>
            }
            else if (message.Role == ChatRole.User.ToString())
            {
                <UserMessage>
                    <MarkdownText Text="@message.Content"></MarkdownText>
                </UserMessage>
            }
        }
    }
    <LoadingIndicator IsLoading="@isLoading" StreamingText="" />
</ChatMessageWrapper>
<ChatInput OnSendMessage="HandleSendMessage"
           IsLoading="@isLoading" />

@code {

    bool isLoading = false;
    private string apiKey = string.Empty;
    private GroqApiClient chatClient = null!;
    private string responseMessage = string.Empty;
    private JsonArray history = [];

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        // Logic to handle the sent message
        apiKey = configuration["Chat:AI:ApiKey"] ?? throw new InvalidOperationException("Missing configuration: Endpoint. See the README for details");
        chatClient = new GroqApiClient(apiKey!);

        history = new JsonArray
        {
            new JsonObject
            {
                ["role"] = "system",
                ["content"] = "You are an AI assistant that tries to answer the user's query."
            }
        };

        var request = new JsonObject
        {
            ["model"] = GroqModels.KimiK2,
            ["messages"] = history
        };

        JsonObject? response = await chatClient.CreateChatCompletionAsync(request);
        var message = GroqResponseHelper.GetMessage(Convert.ToString(response));
        responseMessage = message.Content;
        history.Add(new JsonObject
        {
            ["role"] = message.Role,
            ["content"] = message.Content
        });
        isLoading = false;
    }

    private async Task HandleSendMessage(string message)
    {
        isLoading = true;
        // Logic to handle the sent message

        history.Add(new JsonObject
        {
            ["role"] = Convert.ToString(ChatRole.User),
            ["content"] = message
        });

        var userRequest = new JsonObject
        {
            ["model"] = GroqModels.KimiK2,
            ["messages"] = RequestHelper.DeepCloneMessages(history)
        };

        JsonObject? userResponse = await chatClient.CreateChatCompletionAsync(userRequest);
        var response = GroqResponseHelper.GetMessage(Convert.ToString(userResponse));

        history.Add(new JsonObject
        {
            ["role"] = response.Role,
            ["content"] = response.Content
        });

        isLoading = false;
    }

    @* private void HandleSendImage(byte[] imageBytes, string mediaType)
