    private async Task HandleSendImage(string filePath)
    {
        try{
            chatHistory.Add(new JsonObject
            {
                ["role"] = Convert.ToString(ChatRole.User),
                ["content"] = new JsonArray
                {
                    new JsonObject
                    {
                        ["type"] = "text",
                        ["text"] = "I will ask questions about this image.",
                    },
                    new JsonObject
                    {
                        ["type"] = "image_url",
                        ["image_url"] = new JsonObject
                        {
                            ["url"] = "https://i.ibb.co/zW6nC74x/image.png"
                        }     
                    }
                }
            });

            customHistory.Add(new JsonObject
            {
                ["role"] = Convert.ToString(ChatRole.User),
                ["content"] = "I will ask questions about this image.",
                ["type"] = "Image",
                ["filePath"] = $"temp\\{Path.GetFileName(filePath)}"
            });

            var userResponse = await chatClient.CreateVisionCompletionWithBase64ImageAsync(
                imagePath: filePath,
                //prompt: "I will ask questions about this picture in future.",
                prompt: "I will ask questions about this image.",
                //prompt: "",
                model: GroqModels.Llama4Scout
            );

            var response = GroqResponseHelper.GetMessage(Convert.ToString(userResponse));

            chatHistory.Add(new JsonObject
            {
                ["role"] = response.Role,
                ["content"] = response.Content
            });

            customHistory.Add(new JsonObject
            {
                ["role"] = response.Role,
                ["content"] = response.Content,
                ["type"] = "Text"
            });
        } catch(Exception){
            throw;
        }
    }

    private async Task GetFileData(InputFileChangeEventArgs e)
    {
        isLoading = true;

        if (e is null) return;
        // Fully flush out the uploaded file Stream into a MemoryStream then copy into the byte[]
        var file = e.File;
        var fileContent = new StreamContent(file.OpenReadStream());

        using var ms = new MemoryStream();

        byte[]? imgBytes = null;
        await fileContent.CopyToAsync(ms);
        imgBytes = ms.ToArray();

        var trustedFileName = $"{Guid.NewGuid().ToString("N").Substring(0, 10)}_{file.Name}";
        var uploadDirectory = Path.Combine(environment.WebRootPath, "temp");

        if(!Directory.Exists(uploadDirectory))
            Directory.CreateDirectory(uploadDirectory);

        var filePath = Path.Combine(uploadDirectory, trustedFileName);

        // Save the file to the server using a FileStream
        await using FileStream fs = new(filePath, FileMode.Create);
        await file.OpenReadStream().CopyToAsync(fs);

        ms.Close();
        fs.Close();

        await HandleSendImage(filePath);
        isLoading = false;
    }
