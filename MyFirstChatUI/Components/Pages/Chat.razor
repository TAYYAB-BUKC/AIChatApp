@page "/"
@page "/chat"
@using GroqApiLibrary
@using System.Text.Json.Nodes
@using Microsoft.Extensions.AI
@using MyFirstChatUI.Helpers.Groq
@inject IConfiguration configuration
@inject IWebHostEnvironment environment

<PageTitle>Home</PageTitle>
<ChatMessageWrapper>
    @{
        var messages = customHistory.Cast<JsonObject>().Select(msg => new
        {
            Role = Convert.ToString(msg["role"]),
            Content = Convert.ToString(msg["content"]),
            Type = Convert.ToString(msg["type"]),
            FilePath = Convert.ToString(msg["filePath"])
        }).ToList();

        foreach (var message in messages)
        {
            if (message.Role == ChatRole.Assistant.ToString())
            {
                <AssistantMessage>
                    <MarkdownText Text="@message.Content"></MarkdownText>
                </AssistantMessage>
            }
            else if (message.Role == ChatRole.User.ToString())
            {
                if(message.Type == "Text"){
                    <UserMessage>
                        <MarkdownText Text="@message.Content"></MarkdownText>
                    </UserMessage>
                }

                if (message.Type == "Image")
                {
                    <UserMessage>
                        <img src="@message.FilePath" alt="User uploaded image" style="max-width: 200px; max-height: 200px;" />
                        <MarkdownText Text="@message.Content"></MarkdownText>
                    </UserMessage>
                }
            }
        }
    }
    <LoadingIndicator IsLoading="@isLoading" StreamingText="@streamingResponse" />
</ChatMessageWrapper>
<ChatInput OnSendMessage="HandleSendMessage" OnFileAttachment="GetFileData"
IsLoading="@isLoading" />

